<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    tools:context=".doctor.ManageScheduleActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3B7597"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_back_arrow_white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MediSync - Smart Medicine Reminder"
                android:textSize="12sp"
                android:textColor="#A5D6A7"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage Schedule"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Step 1: Select Patient -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1: Select Patient"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#124170"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerPatients"
                    android:layout_width="match_parent"
                    android:layout_height="48dp" />
            </LinearLayout>

            <!-- Patient Information -->
            <LinearLayout
                android:id="@+id/patientInfoSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_blue"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/tvPatientName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:text="Patient Name"/>
                <TextView
                    android:id="@+id/tvPatientEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"
                    android:text="Email"/>
            </LinearLayout>

            <!-- Step 2: Schedule Range & Remarks -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 2: Schedule Settings"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#124170"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">
                    <Button
                        android:id="@+id/btnStartDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Start Date"
                        android:layout_marginEnd="4dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <Button
                        android:id="@+id/btnEndDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="End Date"
                        android:layout_marginStart="4dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/etRemarks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Remarks (e.g. For Blood Pressure)"
                    android:inputType="textMultiLine"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- Step 3: Add Medicine -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 3: Add Medicine"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#124170"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etMedicineName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Medicine Name (e.g. Paracetamol 500mg)"
                    android:inputType="text"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <EditText
                        android:id="@+id/etIntakeAmount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Amount"
                        android:inputType="numberDecimal"/>
                    <Spinner
                        android:id="@+id/spinnerUnit"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1" />
                </LinearLayout>

                <Spinner
                    android:id="@+id/spinnerInstruction"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"/>

                <!-- Intake Times -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Intake Times"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"/>
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:id="@+id/tvSelectedTimes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="No Times Added"
                        android:textColor="#666666"/>
                    <Button
                        android:id="@+id/btnAddTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add Time"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnAddMedicine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+ Add Medicine To List"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#3B7597"/>
            </LinearLayout>

            <!-- Step 4: Save -->
            <Button
                android:id="@+id/btnSaveSchedule"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Full Schedule"
                android:backgroundTint="#2E7D32"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
