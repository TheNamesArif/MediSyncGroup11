<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".doctor.ManageScheduleActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3B7597"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_back_arrow_white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MediSync - Smart Medicine Reminder"
                android:textSize="14sp"
                android:textColor="#A5D6A7"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage Medicine"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Step 1: Select Patient -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1: Select Patient"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#124170"
                    android:layout_marginBottom="12dp"/>

                <Spinner
                    android:id="@+id/spinnerPatients"
                    android:layout_width="match_parent"
                    android:layout_height="48dp" />

            </LinearLayout>

            <!-- Step 2: Patient Information -->
            <LinearLayout
                android:id="@+id/patientInfoSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_blue"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 2: Patient Information"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Name:"
                        android:textColor="#E0E0E0"/>
                    <TextView
                        android:id="@+id/tvPatientName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="N/A"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Email:"
                        android:textColor="#E0E0E0"/>
                    <TextView
                        android:id="@+id/tvPatientEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="N/A"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Age:"
                        android:textColor="#E0E0E0"/>
                    <TextView
                        android:id="@+id/tvPatientAge"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="N/A"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Step 3: Date Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 3: Schedule Date"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#124170"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select Date"
                    android:textSize="15sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnSelectDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change Date"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="#3B7597"
                    app:strokeColor="#3B7597"/>

            </LinearLayout>

            <!-- Step 4: Add Medicine -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 4: Add Medicine"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#124170"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/etMedicineName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Medicine Name / e.g 500mg"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etIntakeAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Intake Amount (berapa bijik)"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"/>

                <Spinner
                    android:id="@+id/spinnerInstruction"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnAddMedicine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+ Add To List"
                    android:backgroundTint="#3B7597"/>

            </LinearLayout>

            <!-- Step 5: Save -->
            <Button
                android:id="@+id/btnSaveSchedule"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save Schedule"
                android:backgroundTint="#2E7D32"
                android:textStyle="bold"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
