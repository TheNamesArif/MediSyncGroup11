<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Patient Name (Visible for Doctor) -->
        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Patient: John Doe"
            android:textSize="12sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMedName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medicine Name"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <TextView
                    android:id="@+id/tvMedAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500mg - 1 Tablet"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tvMedInstruction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="After Meal"
                    android:textSize="12sp"
                    android:textColor="#3B7597"
                    android:textStyle="italic"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDING"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_card_blue"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#EEEEEE"
            android:layout_marginVertical="10dp"/>

        <!-- Intake Times Row -->
        <TextView
            android:id="@+id/tvIntakeTimes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Times: 09:00 AM, 03:00 PM, 09:00 PM"
            android:textSize="12sp"
            android:textColor="#124170"
            android:textStyle="bold"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
