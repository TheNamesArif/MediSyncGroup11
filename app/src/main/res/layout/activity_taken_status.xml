<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal"
    android:background="#F2F6FA">

    <!-- Medicine card (reused from item_medicine_dashboard.xml) -->
    <include
        android:id="@+id/medicineCard"
        layout="@layout/item_medicine_dashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"/>

    <!-- Action buttons -->
    <Button
        android:id="@+id/btnMarkTaken"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Mark as Taken"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp"/>

    <Button
        android:id="@+id/btnMarkMissed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Mark as Missed"
        android:backgroundTint="#C62828"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp"/>

    <Button
        android:id="@+id/btnMarkPending"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Mark as Pending"
        android:backgroundTint="#1976D2"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp"/>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Back"
        android:backgroundTint="#888888"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp"/>

</LinearLayout>